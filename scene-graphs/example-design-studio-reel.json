          "Brand Identity",
          "Brand Strategy",
          "Brand Story",
          "Graphic Design",
          "Video Production",
          "Video Editing",
          "Content Creation"
        ],
        "rotationDeg": -8,
        "startFrame": 0
      }
    },
    {
      "id": "tilted-card-carousel",
      "type": "TiltedCardCarousel",
      "durationFrames": 120,
      "transitionIn": { "type": "slide-left", "durationFrames": 15 },
      "props": {
        "startFrame": 5,
        "cardStagger": 10
      }
    },
    {
      "id": "circle-motif",
      "type": "CircleMotifTransition",
      "durationFrames": 120,
      "transitionIn": { "type": "fade", "durationFrames": 15 },
      "props": {
        "startFrame": 10,
        "circleStagger": 12
      }
    },
    {
      "id": "logo-reveal-outro",
      "type": "LogoRevealOutro",
      "durationFrames": 120,
      "transitionIn": { "type": "fade", "durationFrames": 20 },
      "props": {
        "startFrame": 5
      }
    }
