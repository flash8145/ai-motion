          "import { Database } from '@your-saas/sdk';",
          "",
          "const db = new Database({",
          "  apiKey: process.env.YOUR_SAAS_API_KEY",
          "});",
          "",
          "async function getUserData(userId: string) {",
          "  const user = await db.users.get(userId);",
          "  return user;",
          "}",
          "",
          "// Real-time data sync, powered by WebSockets"
