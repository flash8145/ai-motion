          "",
          "async function fetchData(query: string) {",
          "  const db = new Database();",
          "  const result = await db.query(query);",
          "  return result.rows;",
          "}",
          "",
          "// Real-time data streaming with WebSockets",
          "const ws = new WebSocket('wss://api.acme.com/stream');",
