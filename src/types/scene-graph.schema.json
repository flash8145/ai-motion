{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VideoProject",
  "description": "Schema definition for the AI Motion Graphics Platform scene graph.",
  "type": "object",
  "required": ["version", "metadata", "theme", "scenes"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "required": ["title", "width", "height", "fps", "totalDurationSec"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "integer", "enum": [24, 25, 30, 50, 60] },
        "totalDurationSec": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "theme": {
      "type": "object",
      "required": ["stylePreset", "colors", "typography", "glassmorphism", "borderRadius"],
      "additionalProperties": false,
      "properties": {
        "stylePreset": {
          "type": "string",
          "enum": [
            "Apple",
            "Stripe",
            "Linear",
            "Notion",
            "ModernSaaS",
            "Enterprise",
            "Futuristic",
            "Neon",
            "Minimal",
            "Warm",
            "Ocean",
            "Sunset",
            "Midnight",
            "DeepBlue"
          ]
        },
        "colors": {
          "type": "object",
          "required": ["background", "surface", "primary", "secondary", "text", "mutedText", "accent", "border", "charts"],
          "additionalProperties": false,
          "properties": {
            "background": { "type": "string" },
            "surface": { "type": "string" },
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "text": { "type": "string" },
            "mutedText": { "type": "string" },
            "accent": { "type": "string" },
            "border": { "type": "string" },
            "charts": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        },
        "typography": {
          "type": "object",
          "required": ["headingFont", "bodyFont", "monoFont"],
          "additionalProperties": false,
          "properties": {
            "headingFont": { "type": "string" },
            "bodyFont": { "type": "string" },
            "monoFont": { "type": "string" }
          }
        },
        "glassmorphism": { "type": "boolean" },
        "borderRadius": { "type": "number", "minimum": 0 }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Scene"
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "musicUrl": { "type": "string", "format": "uri" },
        "musicVolume": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  },
  "definitions": {
    "Scene": {
      "type": "object",
      "required": ["id", "type", "durationFrames", "props"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "TitleReveal",
            "KineticText",
            "DashboardShowcase",
            "CTASection",
            "TestimonialCards",
            "PricingTable",
            "FeatureGrid",
            "StatsCounter",
            "LogoShowcase",
            "SplitScreen",
            "ChartShowcase",
            "ComparisonScene",
            "InteractiveCodeMockup",
            "PromptCard",
            "OverlayHeadline",
            "GalleryGrid",
            "WorkspaceShowcase",
            "ContentWall",
            "ProductReveal",
            "ToolbarMockup",
            "RotatedWordStack",
            "TiltedCardCarousel",
            "CircleMotifTransition",
            "LogoRevealOutro",
            "FreeformAnimation",
            "PathDrawScene",
            "IconMorph",
            "ProcessFlow",
            "LottieScene",
            "WhiteboardReveal",
            "Product3DReveal",
            "ParticleField",
            "GlobeAnimation",
            "LogoExtrude3D",
            "ShaderBackground3D",
            "GlitchTextReveal",
            "ShinyTextSweep",
            "DecryptText",
            "LogoMarquee",
            "TrueFocus",
            "VariableProximity",
            "ClickSpark",
            "PixelTransition",
            "NeonTextReveal",
            "OrbitalCircles",
            "NeonWaveLines",
            "AppLogoReveal",
            "CleanCardPromo",
            "EyeOutlineScene",
            "AppDemoHero",
            "NotificationStack",
            "VoiceInputBar",
            "AppIconOrbit",
            "ScreenRecordingMockup",
            "FeatureTextPanel",
            "AppDemoOutro"
          ]
        },
        "durationFrames": { "type": "integer", "minimum": 1 },
        "transitionIn": {
          "type": "object",
          "required": ["type", "durationFrames"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["fade", "slide-up", "slide-left", "zoom", "none"]
            },
            "durationFrames": { "type": "integer", "minimum": 0 }
          }
        },
        "props": { "type": "object" },
        "overlays": {
          "type": "array",
          "items": { "$ref": "#/definitions/OverlayLayer" }
        },
        "keyframes": {
          "type": "array",
          "items": { "$ref": "#/definitions/Keyframe" }
        },
        "staggerGroup": { "$ref": "#/definitions/StaggerGroup" },
        "camera": { "$ref": "#/definitions/Camera" },
        "textLayer": { "$ref": "#/definitions/TextLayer" }
      }
    },
    "OverlayLayer": {
      "type": "object",
      "required": ["id", "type", "startTimeFrame", "durationFrames", "position", "animation", "props"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["text", "cursor", "badge", "arrow", "zoom-focus", "electric-border"]
        },
        "startTimeFrame": { "type": "integer", "minimum": 0 },
        "durationFrames": { "type": "integer", "minimum": 1 },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number", "minimum": 0 },
            "height": { "type": "number", "minimum": 0 }
          }
        },
        "animation": {
          "type": "object",
          "required": ["type", "durationFrames"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["pop", "fade", "draw-path", "float"]
            },
            "durationFrames": { "type": "integer", "minimum": 1 }
          }
        },
        "props": { "type": "object" }
      }
    },
    "Keyframe": {
      "type": "object",
      "required": ["frame", "value"],
      "additionalProperties": false,
      "properties": {
        "frame": { "type": "integer", "minimum": 0 },
        "value": { "type": "number" },
        "easing": { "$ref": "#/definitions/EasingConfig" }
      }
    },
    "EasingConfig": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cubic-bezier", "linear", "ease-in", "ease-out", "ease-in-out"]
        },
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" }
      }
    },
    "StaggerGroup": {
      "type": "object",
      "required": ["children", "offsetFrames"],
      "additionalProperties": false,
      "properties": {
        "children": {
          "type": "array",
          "items": { "type": "string" }
        },
        "offsetFrames": { "type": "integer" },
        "direction": {
          "type": "string",
          "enum": ["forward", "backward", "center"]
        }
      }
    },
    "Camera": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["perspective", "orthographic"]
        },
        "fov": { "type": "number" },
        "position": {
          "type": "object",
          "required": ["x", "y", "z"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        }
      }
    },
    "TextLayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tracking": { "type": "number" },
        "maskReveal": { "type": "boolean" },
        "variableWeight": { "type": "boolean" }
      }
    }
  }
}
